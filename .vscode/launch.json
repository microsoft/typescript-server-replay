    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch install",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/dist/cli.js",
            "outFiles": [
                "${workspaceFolder}/**/*.js"
            ],
            "args": ["install", "../code/TypeScript"],
            "preLaunchTask": "npm: build"
        }
    ]
}